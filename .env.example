# Google Gemini API key (required for LLM fallback)
GEMINI_API_KEY=...

# Path to SQLite registry database (default: ./migrator.db)
REGISTRY_DB_PATH=./migrator.db

# Optional: Redshift connection string for EXPLAIN validation
# REDSHIFT_DSN=redshift+redshift_connector://user:pass@host:5439/dbname

# API server settings
API_HOST=0.0.0.0
API_PORT=8000

# LLM settings
LLM_MODEL=gemini-3-flash-preview
LLM_ENABLE=true
